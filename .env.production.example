# VRESIQ Backend Production Environment Template
# Copy to .env on the production host and replace all placeholder values.

SERVER_PORT=8081

# Database (MongoDB Atlas production cluster)
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<atlas_cluster>/<prod_db_name>?retryWrites=true&w=majority&appName=<app_name>

# Security
JWT_SECRET=<64+_char_high_entropy_secret>

# Frontend + CORS (comma-separated if multiple)
FRONTEND_URL=https://app.vresiq.com

# SMTP (Brevo/SMTP relay production)
VRESIQ_MAIL_USERNAME=<smtp_username>
VRESIQ_MAIL_PASSWORD=<smtp_password_or_api_key>
MAIL_FROM=noreply@vresiq.com

# Cloudinary
CLOUD_NAME=<cloudinary_cloud_name>
CLOUD_KEY=<cloudinary_api_key>
CLOUD_SECRET=<cloudinary_api_secret>

# Razorpay (sandbox for pre-prod; live for production cutover)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<razorpay_test_secret>

# AI Provider Keys
AI_API_KEY=<openrouter_or_provider_key>
GEMINI_API_KEY=<optional_fallback_key>

# Seeder (optional, one-time bootstrap)
SEED_ADMIN_EMAIL=admin@vresiq.com
SEED_ADMIN_PASSWORD=<strong_admin_password>
